        "i18n"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/michaeldk/vite-plugin-static-twig.git"
    },
    "bugs": {
        "url": "https://github.com/michaeldk/vite-plugin-static-twig/issues"
    },
    "homepage": "https://github.com/michaeldk/vite-plugin-static-twig#readme",
    "engines": {
        "node": ">=18"
    },
    "dependencies": {
        "twig": "^1.17.1"
    },
